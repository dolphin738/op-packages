
config system
	option hostname 'RedmiAX6S'
	option timezone 'CST-8'
	option zonename 'Asia/Shanghai'
	option ttylogin '0'
	option log_size '128'
	option urandom_seed '0'
	option compat_version '2.0'
	option log_proto 'udp'
	option conloglevel '8'
	option cronloglevel '7'
	option zram_comp_algo 'zstd'
	option zram_size_mb '61'

config timeserver 'ntp'
	list server 'ntp.tencent.com'
	list server 'ntp1.aliyun.com'
	list server 'ntp.ntsc.ac.cn'
	list server 'cn.ntp.org.cn'

config led 'led_wan'
	option name 'WAN'
	option sysfs 'blue:net'
	option trigger 'netdev'
	option mode 'link tx rx'
	option dev 'wan'

config imm_init
	option lang '1'
	option system_chn '1'
	option opkg_mirror 'https://mirrors.pku.edu.cn/immortalwrt'

